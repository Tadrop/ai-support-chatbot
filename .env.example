# =============================================================================
# GreenLeaf Customer Service Chatbot — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env.
# =============================================================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# --- Voyage AI (embeddings) ---
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3
VOYAGE_EMBED_DIM=1024

# --- Pinecone (vector DB) ---
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=greenleaf-kb
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Crawler ---
# Root URL of the site to crawl. The crawler discovers pages via sitemap.xml first,
# then falls back to following links from this URL.
CRAWL_ROOT_URL=https://www.greenleafgardensupplies.example
CRAWL_MAX_PAGES=2000
CRAWL_CONCURRENCY=4
CRAWL_REQUEST_TIMEOUT_S=20
CRAWL_USER_AGENT=GreenLeafChatbotCrawler/1.0 (+contact: ops@greenleaf.example)

# --- Chunking ---
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=50

# --- Retrieval / chat ---
RETRIEVAL_TOP_K=6
RETRIEVAL_CONFIDENCE_THRESHOLD=0.62   # below this → handoff
EMBED_CACHE_TTL_SECONDS=3600

# --- Handoff ---
HANDOFF_CHANNEL=email                  # email | crisp
HANDOFF_EMAIL_TO=support@greenleaf.example
CRISP_WEBSITE_ID=
CRISP_API_IDENTIFIER=
CRISP_API_KEY=

# --- Email (SMTP) — used when HANDOFF_CHANNEL=email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=app-password-here
SMTP_FROM=chatbot@greenleaf.example

# --- Dashboard ---
DB_PATH=./greenleaf.db
# REQUIRED for production. Any string; treat as a password. /dashboard/*
# returns 503 if this is empty. Pass as: `Authorization: Bearer <token>`.
DASHBOARD_TOKEN=change-me-to-a-long-random-string

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=30/minute        # per IP, per endpoint
RATE_LIMIT_SESSION=5/minute      # per IP — sessions are precious

# --- CORS ---
CORS_ORIGINS=https://www.greenleafgardensupplies.example

# --- App ---
APP_ENV=dev                            # dev | staging | prod
LOG_LEVEL=INFO
